@model CreateSalesInvoiceViewModel
@{
    ViewData["Title"] = "Create Invoice";
    ViewData["ActiveNav"] = "Sales";
    ViewData["ActiveSubNav"] = "CreateInvoice";
    ViewData["Shell"] = "light";
}

<form asp-action="CreateInvoice" method="post" class="invoice-builder" data-invoice-form>
    <div class="invoice-top-grid">
        <section class="panel invoice-section">
            <h2>Customer Selection</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerName" class="form-label">Select Customer</label>
                    <input asp-for="CustomerName" class="form-control" list="customer-list" placeholder="Choose a client..." />
                    <datalist id="customer-list">
                        @foreach (var customer in Model.CustomerOptions)
                        {
                            <option value="@customer"></option>
                        }
                    </datalist>
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BillingAddress" class="form-label">Billing Address</label>
                    <input asp-for="BillingAddress" class="form-control" list="address-list" placeholder="Select or type address..." />
                    <datalist id="address-list">
                        @foreach (var address in Model.BillingAddressOptions)
                        {
                            <option value="@address"></option>
                        }
                    </datalist>
                    <span asp-validation-for="BillingAddress" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="panel invoice-identity">
            <h2>Invoice Identity</h2>
            <p><span>Invoice Number</span><strong>@Model.InvoiceNumber</strong></p>
            <input asp-for="InvoiceNumber" type="hidden" />
            <div>
                <label asp-for="Currency" class="form-label">Currency</label>
                <select asp-for="Currency" class="form-select">
                    <option>USD ($)</option>
                    <option>PKR (Rs)</option>
                    <option>EUR (€)</option>
                </select>
            </div>
        </section>
    </div>

    <section class="panel invoice-section">
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="InvoiceDate" class="form-label">Invoice Date</label>
                <input asp-for="InvoiceDate" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="DueDate" class="form-label">Due Date</label>
                <input asp-for="DueDate" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="PaymentTerms" class="form-label">Payment Terms</label>
                <select asp-for="PaymentTerms" class="form-select">
                    <option>Net 7</option>
                    <option>Net 14</option>
                    <option>Net 30</option>
                    <option>Due on Receipt</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="PONumber" class="form-label">P.O. Number</label>
                <input asp-for="PONumber" class="form-control" placeholder="Optional" />
            </div>
        </div>
    </section>

    <section class="panel invoice-section">
        <div class="panel-title-row">
            <h2>Line Items</h2>
            <small>All prices in selected currency</small>
        </div>
        <span asp-validation-for="LineItems" class="text-danger"></span>
        <div class="table-responsive">
            <table class="table supplier-table invoice-lines align-middle">
                <thead>
                    <tr>
                        <th>Product / Description</th>
                        <th>HSN Code</th>
                        <th>Qty</th>
                        <th>Unit</th>
                        <th>Rate</th>
                        <th>Disc %</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody data-line-items>
                    @for (var i = 0; i < Model.LineItems.Count; i++)
                    {
                        <tr data-line-row>
                            <td><input asp-for="LineItems[i].ProductDescription" class="form-control" placeholder="Egyptian Cotton Indigo Twill" /></td>
                            <td><input asp-for="LineItems[i].HSNCode" class="form-control" placeholder="5208" /></td>
                            <td><input asp-for="LineItems[i].Quantity" class="form-control" type="number" step="0.01" min="0.01" data-line-qty /></td>
                            <td><input asp-for="LineItems[i].Unit" class="form-control" /></td>
                            <td><input asp-for="LineItems[i].Rate" class="form-control" type="number" step="0.01" min="0" data-line-rate /></td>
                            <td><input asp-for="LineItems[i].DiscountPercent" class="form-control" type="number" step="0.01" min="0" max="100" data-line-discount /></td>
                            <td><strong data-line-total>$0.00</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-outline-primary btn-sm" type="button" data-add-line><i class="fa-solid fa-plus me-1"></i>Add Row</button>
    </section>

    <div class="invoice-bottom-grid">
        <section class="panel invoice-section">
            <h2>Payment Terms & Notes</h2>
            <textarea asp-for="Notes" class="form-control" rows="5" placeholder="Standard payment within 30 days. Late payments are subject to 2.5% monthly interest."></textarea>
        </section>
        <section class="panel invoice-summary">
            <label asp-for="TaxRate" class="form-label">GST Rate (%)</label>
            <input asp-for="TaxRate" class="form-control mb-3" type="number" step="0.01" min="0" max="100" data-tax-rate />
            <p><span>Subtotal</span><strong data-subtotal>$0.00</strong></p>
            <p><span>GST</span><strong data-tax>$0.00</strong></p>
            <p><span>Round off</span><strong data-round>$0.00</strong></p>
            <p class="grand"><span>Grand Total</span><strong data-grand-total>$0.00</strong></p>
        </section>
    </div>

    <div class="invoice-actions">
        <button class="btn btn-outline-primary btn-sm" type="submit" name="SubmitAction" value="Draft">Save as Draft</button>
        <button class="btn btn-light btn-sm" type="button" onclick="window.print()">Preview Invoice</button>
        <button class="btn btn-primary btn-sm ms-auto" type="submit" name="SubmitAction" value="Finalize"><i class="fa-solid fa-paper-plane me-1"></i>Finalize & Send</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
