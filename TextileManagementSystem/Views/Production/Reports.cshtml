@model ProductionDashboardViewModel
@{
    ViewData["Title"] = "Production Reports";
    ViewData["ActiveNav"] = "Production";
    ViewData["ActiveSubNav"] = "ProductionReports";
    ViewData["Shell"] = "light";
}

<div class="page-heading d-flex flex-wrap justify-content-between gap-3 align-items-start reports-heading">
    <div>
        <h1>Production Reports & Analytics</h1>
        <p>Detailed performance metrics for the current manufacturing cycle.</p>
    </div>
    <div class="report-actions">
        <select class="form-select compact-select"><option>Oct 1, 2023 - Oct 31, 2023</option><option>This Week</option><option>This Quarter</option></select>
        <button class="btn btn-primary" type="button"><i class="fa-solid fa-download"></i> Export Report</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="metric-card report-metric"><span class="metric-icon blue"><i class="fa-solid fa-clipboard-list"></i></span><div><em>Today</em><small>Production Orders</small><strong>@Model.Orders.Count</strong><p>orders</p></div></div></div>
    <div class="col-md-3"><div class="metric-card report-metric"><span class="metric-icon cyan"><i class="fa-solid fa-circle-check"></i></span><div><em>Success</em><small>Completed Orders</small><strong>@Model.Orders.Count(item => item.ProgressPercentage == 100)</strong><p>complete</p></div></div></div>
    <div class="col-md-3"><div class="metric-card report-metric"><span class="metric-icon cyan"><i class="fa-solid fa-box-open"></i></span><div><em>Queue</em><small>Pending Orders</small><strong>@Model.Orders.Count(item => item.ProgressPercentage < 100)</strong><p>in progress</p></div></div></div>
    <div class="col-md-3"><div class="metric-card report-metric"><span class="metric-icon blue"><i class="fa-solid fa-gauge-high"></i></span><div><em>Target</em><small>Stage Efficiency</small><strong>92.4%</strong><p>+2.4%</p></div></div></div>
</div>

<section class="reports-grid">
    <div class="panel report-panel">
        <div class="panel-title-row"><h2>Weekly Production by Stage</h2><span>All</span></div>
        <div class="stacked-chart">
            <div><b class="cutting" style="height:36%"></b><b class="stitching" style="height:25%"></b><b class="finishing" style="height:25%"></b><b class="qc" style="height:14%"></b><small>Mon</small></div>
            <div><b class="cutting" style="height:30%"></b><b class="stitching" style="height:30%"></b><b class="finishing" style="height:22%"></b><b class="qc" style="height:18%"></b><small>Tue</small></div>
            <div><b class="cutting" style="height:40%"></b><b class="stitching" style="height:24%"></b><b class="finishing" style="height:20%"></b><b class="qc" style="height:16%"></b><small>Wed</small></div>
            <div><b class="cutting" style="height:44%"></b><b class="stitching" style="height:22%"></b><b class="finishing" style="height:24%"></b><b class="qc" style="height:10%"></b><small>Thu</small></div>
            <div><b class="cutting" style="height:32%"></b><b class="stitching" style="height:30%"></b><b class="finishing" style="height:22%"></b><b class="qc" style="height:16%"></b><small>Fri</small></div>
        </div>
    </div>

    <div class="panel report-panel">
        <div class="panel-title-row"><h2>Target vs Actual Output</h2><span>Actual - Target</span></div>
        <div class="line-chart">
            <svg viewBox="0 0 420 210" preserveAspectRatio="none" aria-hidden="true">
                <path d="M0 140 C55 105, 85 145, 128 132 C180 116, 175 60, 230 72 C282 84, 286 150, 325 148 C370 145, 385 114, 420 50" />
                <path class="target-line" d="M0 135 L420 135" />
            </svg>
        </div>
    </div>

    <div class="panel report-panel">
        <div class="panel-title-row"><h2>Departmental Trends</h2><span>Monthly</span></div>
        <div class="area-chart">
            <svg viewBox="0 0 420 210" preserveAspectRatio="none" aria-hidden="true">
                <path class="area-fill" d="M0 150 C72 168, 120 145, 170 128 C235 106, 288 95, 420 105 L420 210 L0 210 Z" />
                <path d="M0 150 C72 168, 120 145, 170 128 C235 106, 288 95, 420 105" />
            </svg>
        </div>
        <div class="legend-row"><span><b></b> Cutting Dept</span><span><b class="muted-dot"></b> Stitching Dept</span></div>
    </div>

    <div class="panel report-panel">
        <div class="panel-title-row"><h2>Bottleneck Analysis</h2><span class="critical-pill">Critical Stage: Stitching</span></div>
        <div class="donut-report">
            <div class="donut-ring"><strong>4.2h</strong><small>Avg Delay</small></div>
            <ul>
                <li><b class="cutting-dot"></b>Cutting <strong>40%</strong></li>
                <li><b class="stitching-dot"></b>Stitching <strong>25%</strong></li>
                <li><b class="finishing-dot"></b>Finishing <strong>15%</strong></li>
                <li><b class="qc-dot"></b>Quality Check <strong>20%</strong></li>
            </ul>
        </div>
    </div>
</section>

<section class="panel report-summary">
    <div class="panel-title-row"><h2>Production Order Summary</h2><a asp-controller="Production" asp-action="StageTracker">View All Orders</a></div>
    <div class="table-responsive">
        <table class="table supplier-table align-middle">
            <thead><tr><th>Order ID</th><th>Item</th><th>Quantity</th><th>Current Stage</th><th>Completion %</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var order in Model.Orders.Take(6))
                {
                    <tr><td><strong>#@order.OrderNumber</strong></td><td>@order.ItemName</td><td>@order.Quantity.ToString("N0") Units</td><td><span class="status good blue-status">@order.CurrentStage</span></td><td><div class="completion-line"><b style="width:@order.ProgressPercentage%"></b></div>@order.ProgressPercentage%</td><td><a asp-action="EditOrder" asp-route-id="@order.Id"><i class="fa-regular fa-eye"></i></a></td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="table-footer"><small>Showing 4 of 132 reports</small><div class="pager"><button>Prev</button><button>Next</button></div></div>
</section>
