@model Employee
@{
    ViewData["Title"] = "Add New Employee";
    ViewData["ActiveNav"] = "HR";
    ViewData["ActiveSubNav"] = "AddEmployee";
    ViewData["Shell"] = "light";
}

<div class="page-heading hr-heading">
    <div>
        <h1>Add New Employee</h1>
        <p>Register a new staff member to the FabricFlow ecosystem.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Directory">Cancel</a>
        <button class="btn btn-primary" form="employee-form" type="submit">Save Employee</button>
    </div>
</div>

<form id="employee-form" asp-action="AddEmployee" method="post" class="hr-form-shell">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="hr-form-section">
        <h2><i class="fa-solid fa-user"></i> Personal Information</h2>
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <label class="photo-upload">
                    <i class="fa-solid fa-camera-retro"></i>
                    <span>Upload Photo</span>
                    <small>Max 2MB JPG or PNG</small>
                </label>
            </div>
            <div class="col-md-9">
                <div class="row g-3">
                    <div class="col-md-6"><label asp-for="FullName" class="form-label">Full Name</label><input asp-for="FullName" class="form-control" placeholder="e.g. Robert Smith" /><span asp-validation-for="FullName" class="text-danger"></span></div>
                    <div class="col-md-6"><label asp-for="DateOfBirth" class="form-label">Date of Birth</label><input asp-for="DateOfBirth" class="form-control" type="date" /></div>
                    <div class="col-md-6"><label asp-for="Gender" class="form-label">Gender</label><select asp-for="Gender" class="form-select"><option>Female</option><option>Male</option></select></div>
                    <div class="col-md-6"><label asp-for="MobileNumber" class="form-label">Mobile Number</label><input asp-for="MobileNumber" class="form-control" placeholder="+1 (555) 000-0000" /><span asp-validation-for="MobileNumber" class="text-danger"></span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="hr-form-section">
        <h2><i class="fa-solid fa-briefcase"></i> Employment Details</h2>
        <div class="row g-3">
            <div class="col-md-3"><label asp-for="EmployeeCode" class="form-label">Employee ID</label><input asp-for="EmployeeCode" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Designation" class="form-label">Designation</label><input asp-for="Designation" class="form-control" placeholder="e.g. Master Tailor" /></div>
            <div class="col-md-3"><label asp-for="Department" class="form-label">Department</label><select asp-for="Department" class="form-select"><option>Weaving</option><option>Stitching</option><option>Quality Control</option><option>Logistics</option></select></div>
            <div class="col-md-3"><label asp-for="JoiningDate" class="form-label">Joining Date</label><input asp-for="JoiningDate" class="form-control" type="date" /></div>
            <div class="col-md-6"><label asp-for="Role" class="form-label">Role</label><input asp-for="Role" class="form-control" placeholder="e.g. Lead Supervisor" /></div>
            <div class="col-md-6"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select"><option>Active</option><option>Inactive</option><option>On Leave</option><option>Suspended</option></select></div>
        </div>
    </div>

    <div class="hr-form-section">
        <h2><i class="fa-solid fa-money-bill-wave"></i> Payroll & Benefits</h2>
        <div class="row g-3">
            <div class="col-md-4"><label asp-for="BasicSalary" class="form-label">Basic Salary ($)</label><input asp-for="BasicSalary" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="BonusAllowance" class="form-label">Bonus/Allowances</label><input asp-for="BonusAllowance" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="PaymentMode" class="form-label">Payment Mode</label><select asp-for="PaymentMode" class="form-select"><option>Bank Transfer</option><option>Cash</option><option>Cheque</option></select></div>
            <div class="col-md-6"><label asp-for="BankName" class="form-label">Bank Name</label><input asp-for="BankName" class="form-control" placeholder="Enter bank name" /></div>
            <div class="col-md-6"><label asp-for="AccountNumber" class="form-label">Account Number</label><input asp-for="AccountNumber" class="form-control" placeholder="Enter account number" /></div>
            <div class="col-md-6"><label asp-for="CNIC" class="form-label">CNIC</label><input asp-for="CNIC" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Email" class="form-label">Email</label><input asp-for="Email" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label">Address</label><input asp-for="Address" class="form-control" /></div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
