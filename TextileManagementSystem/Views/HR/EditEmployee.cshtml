@model Employee
@{
    ViewData["Title"] = "Edit Employee";
    ViewData["ActiveNav"] = "HR";
    ViewData["ActiveSubNav"] = "EmployeeDirectory";
    ViewData["Shell"] = "light";
}

<div class="breadcrumb-line"><a asp-action="Directory">Employee Directory</a><span>&gt;</span><strong>Edit Employee</strong></div>

<div class="page-heading hr-heading">
    <div>
        <h1>Edit Employee</h1>
        <p>Update employee profile, employment details, payroll settings, and status.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Profile" asp-route-id="@Model.Id">Cancel</a>
        <button class="btn btn-primary" form="employee-edit-form" type="submit">Save Changes</button>
    </div>
</div>

<form id="employee-edit-form" asp-action="EditEmployee" asp-route-id="@Model.Id" method="post" class="hr-form-shell">
    <input asp-for="Id" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="hr-form-section">
        <h2><i class="fa-solid fa-user"></i> Personal Information</h2>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="FullName" class="form-label">Full Name</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="EmployeeCode" class="form-label">Employee ID</label><input asp-for="EmployeeCode" class="form-control" /><span asp-validation-for="EmployeeCode" class="text-danger"></span></div>
            <div class="col-md-4"><label asp-for="CNIC" class="form-label">CNIC</label><input asp-for="CNIC" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="DateOfBirth" class="form-label">Date of Birth</label><input asp-for="DateOfBirth" class="form-control" type="date" /></div>
            <div class="col-md-4"><label asp-for="Gender" class="form-label">Gender</label><select asp-for="Gender" class="form-select"><option>Female</option><option>Male</option></select></div>
            <div class="col-md-6"><label asp-for="MobileNumber" class="form-label">Mobile Number</label><input asp-for="MobileNumber" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Email" class="form-label">Email</label><input asp-for="Email" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label">Address</label><input asp-for="Address" class="form-control" /></div>
        </div>
    </div>

    <div class="hr-form-section">
        <h2><i class="fa-solid fa-briefcase"></i> Employment Details</h2>
        <div class="row g-3">
            <div class="col-md-4"><label asp-for="Department" class="form-label">Department</label><select asp-for="Department" class="form-select"><option>Weaving</option><option>Stitching</option><option>Quality Control</option><option>Logistics</option></select></div>
            <div class="col-md-4"><label asp-for="Designation" class="form-label">Designation</label><input asp-for="Designation" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Role" class="form-label">Role</label><input asp-for="Role" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="JoiningDate" class="form-label">Joining Date</label><input asp-for="JoiningDate" class="form-control" type="date" /></div>
            <div class="col-md-4"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select"><option>Active</option><option>Inactive</option><option>On Leave</option><option>Suspended</option></select></div>
            <div class="col-md-2"><label asp-for="AttendancePercentage" class="form-label">Attendance %</label><input asp-for="AttendancePercentage" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="OvertimeHours" class="form-label">OT Hours</label><input asp-for="OvertimeHours" class="form-control" /></div>
        </div>
    </div>

    <div class="hr-form-section">
        <h2><i class="fa-solid fa-money-bill-wave"></i> Payroll & Benefits</h2>
        <div class="row g-3">
            <div class="col-md-4"><label asp-for="PayType" class="form-label">Pay Type</label><select asp-for="PayType" class="form-select"><option>Monthly Salary</option><option>Monthly Fixed</option><option>Piece Rate</option><option>Daily Rate</option></select></div>
            <div class="col-md-4"><label asp-for="BasicSalary" class="form-label">Basic Salary</label><input asp-for="BasicSalary" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="BonusAllowance" class="form-label">Bonus/Allowances</label><input asp-for="BonusAllowance" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="PaymentMode" class="form-label">Payment Mode</label><select asp-for="PaymentMode" class="form-select"><option>Bank Transfer</option><option>Cash</option><option>Cheque</option></select></div>
            <div class="col-md-4"><label asp-for="BankName" class="form-label">Bank Name</label><input asp-for="BankName" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="AccountNumber" class="form-label">Account Number</label><input asp-for="AccountNumber" class="form-control" /></div>
            <div class="col-12"><label asp-for="Notes" class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="4"></textarea></div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
