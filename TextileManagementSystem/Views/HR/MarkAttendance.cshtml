@model MarkAttendanceViewModel
@{
    ViewData["Title"] = "Mark Daily Attendance";
    ViewData["ActiveNav"] = "HR";
    ViewData["ActiveSubNav"] = "MarkAttendance";
    ViewData["Shell"] = "light";
}

<div class="mark-attendance-layout">
    <main>
        <div class="page-heading hr-heading">
            <div><h1>Mark Daily Attendance</h1><p><i class="fa-regular fa-calendar"></i> @Model.AttendanceDate.ToString("dddd, MMMM dd, yyyy")</p></div>
            <div class="hr-actions"><a class="btn btn-outline-primary" asp-action="AttendanceTracking"><i class="fa-regular fa-clock"></i> View History</a><button class="btn btn-primary" form="attendance-form" type="submit"><i class="fa-solid fa-floppy-disk"></i> Submit Attendance</button></div>
        </div>

        <form id="attendance-form" asp-action="MarkAttendance" method="post">
        <section class="panel mark-filter-panel">
            <div class="row g-3 align-items-end">
                <div class="col-md-3"><label asp-for="AttendanceDate" class="form-label">Date</label><input asp-for="AttendanceDate" class="form-control" type="date" /></div>
                <div class="col-md-5"><label class="form-label">Search Employee</label><input class="form-control" placeholder="Name or Employee ID..." /></div>
                <div class="col-md-2"><label asp-for="Department" class="form-label">Department</label><select asp-for="Department" class="form-select"><option>All Departments</option><option>Weaving</option><option>Stitching</option><option>Quality Control</option><option>Logistics</option></select></div>
                <div class="col-md-2"><label asp-for="Shift" class="form-label">Shift</label><select asp-for="Shift" class="form-select"><option>Morning</option><option>Day</option><option>Night</option></select></div>
                <div class="col-12 d-flex gap-2 flex-wrap"><button class="btn btn-outline-primary"><i class="fa-solid fa-check"></i> Mark All Present</button><button class="btn btn-outline-danger"><i class="fa-solid fa-xmark"></i> Mark All Absent</button><button class="btn btn-light"><i class="fa-solid fa-rotate"></i> Bulk Shift Change</button></div>
            </div>
        </section>

        <section class="panel mt-3">
            <div class="table-responsive">
                <table class="table supplier-table align-middle">
                    <thead><tr><th>Employee</th><th>Status</th><th>Clock In</th><th>Clock Out</th><th>Note</th></tr></thead>
                    <tbody>
                        @for (var i = 0; i < Model.Entries.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input asp-for="Entries[i].EmployeeId" type="hidden" />
                                    <input asp-for="Entries[i].EmployeeName" type="hidden" />
                                    <input asp-for="Entries[i].EmployeeCode" type="hidden" />
                                    <input asp-for="Entries[i].Department" type="hidden" />
                                    <span class="employee-avatar photo-a">@Model.Entries[i].EmployeeName[..1]</span><strong>@Model.Entries[i].EmployeeName</strong><small>@Model.Entries[i].EmployeeCode - @Model.Entries[i].Department</small>
                                </td>
                                <td><select asp-for="Entries[i].Status" class="form-select form-select-sm"><option>Present</option><option>Absent</option><option>Leave</option><option>Late</option></select></td>
                                <td><input asp-for="Entries[i].ClockIn" class="form-control form-control-sm" type="time" /></td>
                                <td><input asp-for="Entries[i].ClockOut" class="form-control form-control-sm" type="time" /></td>
                                <td><input asp-for="Entries[i].Note" class="form-control form-control-sm" placeholder="Note" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer"><small>Showing @Model.Entries.Count employees</small><div class="pager"><button>&lt;</button><button>&gt;</button></div></div>
        </section>
        </form>
    </main>
    <aside class="panel live-summary"><h2>Live Summary</h2><p><span class="present-dot"></span> Present <strong>@Model.Entries.Count(e => e.Status == "Present")</strong></p><p><span class="absent-dot"></span> Absent <strong>@Model.Entries.Count(e => e.Status == "Absent")</strong></p><p><span class="leave-dot"></span> Pending <strong>@Model.Entries.Count(e => e.Status == "Leave")</strong></p></aside>
</div>
