@model SalaryAdvance

<div class="row g-3">
    <div class="col-md-6"><label asp-for="EmployeeId" class="form-label">Employee</label><select asp-for="EmployeeId" asp-items="ViewBag.Employees" class="form-select"></select></div>
    <div class="col-md-6"><label asp-for="RequestCode" class="form-label">Request Code</label><input asp-for="RequestCode" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Amount" class="form-label">Amount</label><input asp-for="Amount" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="RequestedDate" class="form-label">Requested Date</label><input asp-for="RequestedDate" class="form-control" type="date" /></div>
    <div class="col-md-6"><label asp-for="Reason" class="form-label">Reason</label><input asp-for="Reason" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="RepaymentMonths" class="form-label">Repayment Months</label><input asp-for="RepaymentMonths" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select"><option>Pending</option><option>Approved</option><option>Rejected</option></select></div>
    <div class="col-12"><label asp-for="Notes" class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="4"></textarea></div>
</div>
